---
export const prerender = false;
import Layout from "@layouts/DefaultPage.astro";
import {
	isAstroWebsite,
	isValidUrl,
	addProtocolToUrlAndTrim,
	CustomError,
} from "@lib/modules/server";
let title = "isAstro";
let description = "Check if a website is built with Astro";
let result = null;
let checkingError = null;
const urlParam = Astro.url.searchParams.get("url");

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const urlValue = formData.get("url");
	if (typeof urlValue === "string") {
		return Astro.redirect(`?url=${encodeURIComponent(urlValue.trim())}`);
	}
}

if (urlParam) {
	const decodedUrl = decodeURIComponent(addProtocolToUrlAndTrim(urlParam));
	if (!isValidUrl(decodedUrl)) {
		checkingError = true;
		result = { isAstro: false, mechanism: "Invalid URL", url: decodedUrl };
	} else {
		try {
			result = await isAstroWebsite(decodedUrl);
		} catch (error) {
			if (error instanceof CustomError) {
				checkingError = true;
				result = {
					isAstro: false,
					mechanism: error.message,
					url: error.originalUrl,
					lastFetchedUrl: error.lastFetchedUrl,
				};
			} else {
				checkingError = true;
				result = {
					isAstro: false,
					mechanism: "Unable to check",
					url: decodedUrl,
				};
			}
		}
	}
}

if (result) {
	const displayUrl = result.url.replace(/^https?:\/\//, "").replace(/\/+$/, "");
	let status = checkingError ? "Not Sure" : result.isAstro ? "Probably" : "Probably not";
	title = `is ${displayUrl} Astro? ${status}`;
	description = `${result.mechanism}${result.astroVersion ? ` Astro Version: ${result.astroVersion}` : ""}${result.starlightVersion ? ` Starlight Version: ${result.starlightVersion}` : ""}`;
}
---

<Layout {title} {description}>
	<main>
		<div class="glass-card">
			<header>
				<h1>isAstro</h1>
				<p class="subtitle">
					Detect if a site is powered by
					<a href="https://astro.build/">Astro</a>
				</p>
			</header>

			<form method="POST" novalidate>
				<input
					type="url"
					name="url"
					aria-label="Website URL"
					placeholder="https://example.com"
					required
					autofocus
					value={urlParam || ""}
				/>
				<button type="submit">Check Website</button>
			</form>

			{
				result && (
					<div class="result-container">
						<div
							class={`status-box ${checkingError ? "error" : result.isAstro ? "success" : "neutral"}`}
						>
							<p class="status-title">
								{result.isAstro ? "✓ Astro Detected" : checkingError ? "Error" : "Not using Astro"}
							</p>
							<p class="status-mechanism">{result.mechanism}</p>

							{(result.astroVersion || result.starlightVersion) && (
								<div class="versions">
									{result.astroVersion && <span>Astro: {result.astroVersion}</span>}
									{result.starlightVersion && <span>Starlight: {result.starlightVersion}</span>}
								</div>
							)}
						</div>

						<button id="copyButton" type="button" class="copy-link">
							Copy to Share Results
						</button>
					</div>
				)
			}

			<footer>
				<a href="https://github.com/OliverSpeir/isAstro">Source Code</a>
			</footer>
		</div>
	</main>

	<script>
		const copyButton = document.getElementById("copyButton") as HTMLButtonElement;
		if (copyButton) {
			copyButton.addEventListener("click", async () => {
				const prettyUrl = decodeURIComponent(window.location.href);

				try {
					await navigator.clipboard.writeText(prettyUrl);
					const originalText = copyButton.textContent;
					copyButton.textContent = "Copied!";
					setTimeout(() => {
						copyButton.textContent = originalText;
					}, 2000);
				} catch (err) {
					console.error("Failed to copy URL:", err);
				}
			});
		}
	</script>
</Layout>

<style>
	main {
		width: 100%;
		max-width: 448px;
		padding: 16px;
	}

	.glass-card {
		padding: 32px;
		border-radius: 16px;
		backdrop-filter: blur(20px);
		background-color: rgba(24, 24, 27, 0.5);
		border: 1px solid rgba(39, 39, 42, 0.5);
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
	}

	header {
		text-align: center;
		margin-bottom: 32px;
	}

	h1 {
		font-size: 1.875rem;
		font-weight: 700;
		margin: 0 0 8px 0;
	}

	.subtitle {
		color: #a1a1aa;
		font-size: 0.875rem;
		margin: 0;
	}

	.subtitle a {
		color: #d4d4d8;
		text-decoration: underline;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	input {
		width: 100%;
		box-sizing: border-box;
		padding: 12px 16px;
		background-color: rgba(9, 9, 11, 0.5);
		border: 1px solid #27272a;
		border-radius: 8px;
		color: white;
		font-size: 1rem;
		transition: all 0.2s;
	}

	input:focus {
		outline: none;
		border-color: transparent;
		box-shadow: 0 0 0 2px #3f3f46;
	}

	button[type="submit"] {
		width: 100%;
		padding: 12px 16px;
		background-color: #27272a;
		color: white;
		border: none;
		border-radius: 8px;
		font-weight: 500;
		cursor: pointer;
		transition: background-color 0.2s;
	}

	button[type="submit"]:hover {
		background-color: #3f3f46;
	}

	.result-container {
		margin-top: 24px;
	}

	.status-box {
		padding: 16px;
		border-radius: 8px;
		border: 1px solid;
	}

	.success {
		border-color: rgba(6, 78, 59, 0.5);
		background-color: rgba(2, 44, 34, 0.2);
	}

	.success .status-title {
		color: #4ade80;
	}

	.error {
		border-color: rgba(127, 29, 29, 0.5);
		background-color: rgba(69, 10, 10, 0.2);
	}

	.error .status-title {
		color: #f87171;
	}

	.neutral {
		border-color: #27272a;
		background-color: rgba(24, 24, 27, 0.3);
	}

	.neutral .status-title {
		color: #a1a1aa;
	}

	.status-title {
		font-size: 0.875rem;
		font-weight: 500;
		margin: 0;
	}

	.status-mechanism {
		font-size: 0.875rem;
		margin: 4px 0 0 0;
		opacity: 0.7;
	}

	.versions {
		margin-top: 8px;
		font-size: 0.75rem;
		font-family: monospace;
		display: flex;
		flex-direction: column;
		gap: 2px;
		opacity: 0.8;
	}

	.copy-link {
		width: 100%;
		background: none;
		border: none;
		color: #71717a;
		font-size: 0.75rem;
		padding: 8px;
		cursor: pointer;
		margin-top: 16px;
	}

	.copy-link:hover {
		color: #d4d4d8;
	}

	footer {
		margin-top: 40px;
		padding-top: 24px;
		border-top: 1px solid rgba(39, 39, 42, 0.5);
		text-align: center;
	}

	footer a {
		color: #71717a;
		font-size: 0.75rem;
		text-decoration: none;
	}

	footer a:hover {
		color: #d4d4d8;
	}
</style>
